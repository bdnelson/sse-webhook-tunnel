# SSE Webhook Tunnel environment configuration.
# Copy to .env and adjust. Flags override these values.

# SSE source URL to subscribe to (required).
SOURCE_URL=https://smee.io/your-channel

# Target URL each event is forwarded to (required).
TARGET_URL=http://localhost:9000/hook

# Path to the structured log file (optional).
LOG_FILE=sse-webhook-tunnel.log

# Skip TLS verification for the target, for internal self-signed certs (optional).
INSECURE=false
